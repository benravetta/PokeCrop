{
  "name": "cardcrop-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/server.cjs --external:playwright --external:playwright-core",
    "start": "node dist/server.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration:ebay": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "aws4fetch": "^1.0.20",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "fflate": "^0.8.3",
    "get-tsconfig": "^4.13.6",
    "helmet": "^8.2.0",
    "ipaddr.js": "^2.4.0",
    "jimp": "^1.6.1",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.1",
    "stripe": "^22.2.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.4",
    "playwright": "^1.52.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
