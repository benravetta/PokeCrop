# Copy to ".env" and adjust for your deployment:  cp .env.example .env

# Host port the app is published on (maps to the frontend nginx container).
PORT=8080

# Public origin browsers use to reach the app, including scheme and port.
# For a domain behind a TLS-terminating reverse proxy, use e.g. https://gemcheck.co.uk
PUBLIC_ORIGIN=http://localhost:8080

# How long (ms) the backend waits on the Python service before timing out.
PYTHON_TIMEOUT_MS=180000

# Number of uvicorn workers for the Python service (CPU-bound; scale with cores/RAM).
UVICORN_WORKERS=1

# ---- Supabase (accounts / auth / billing) ----
# Backend (server-side, secret — set as Fly secrets, never commit real values):
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SECRET_OR_SERVICE_ROLE_KEY

# Frontend (public, baked into the SPA at build time via Docker build args):
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# ---- Stripe (subscriptions + one-off grade purchase) ----
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Premium (£9.99/mo) — internal plan id `unlimited`
STRIPE_PRICE_UNLIMITED=price_1TldiFIXClJKdqLnZrYEHwrv
# Pro (£19.99/mo)
STRIPE_PRICE_PRO=price_1TldjqIXClJKdqLnKCX3k5Xs
# Enterprise (Pro + REST API) — internal plan id `api`; keep your existing price id
STRIPE_PRICE_API=price_xxx
# One-time (not recurring) GBP price for buying a single AI grade without a
# subscription. Create it in Stripe as a one-time price (e.g. £2.99) and add
# the `checkout.session.completed` event to the webhook endpoint.
STRIPE_PRICE_GRADE_SINGLE=price_1TlSFwIXClJKdqLnqeCH4PnE

# ---- Public API (/v1) rate limits (optional; defaults shown) ----
API_RATE_PER_MIN=60
API_DAILY_SOFT_CAP=5000
API_STRAIGHTEN_RATE_PER_MIN=30

# ---- Cloudflare R2 (crop catalog archive) ----
# When all four are set, every successful full-resolution crop (web + API) is
# archived to R2 under catalog/{tcg}/{set}/{number}/{hash}.png and indexed.
# Leave blank to disable archiving entirely (safe no-op). Create the bucket and
# an S3 API token in the Cloudflare dashboard (R2 > Manage R2 API Tokens).
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=cardcrop-catalog

# ---- AI card identification (OpenAI vision) ----
# When set, each unique archived crop is identified (tcg/set/number/name) by a
# vision model. Runs only after content-hash dedupe, so duplicates cost nothing.
# Leave blank to skip identification (crops still archive under unidentified/).
OPENAI_API_KEY=sk-xxx
# Optional: override the catalog-ID vision model (default: gpt-4o-mini).
CARD_ID_MODEL=gpt-4o-mini

# ---- AI grading (standalone pre-grader) ----
CARD_GRADE_INSPECT_MODEL=gpt-4o
CARD_GRADE_ADJUDICATE_MODEL=gpt-4o-mini
# Rough raw + graded value estimate attached to grade results (GBP). Uses the
# model's general market knowledge — ballpark, not live prices. gpt-4o has the
# best price knowledge; drop to gpt-4o-mini to cut cost at the expense of accuracy.
CARD_PRICE_MODEL=gpt-4o
# Optional: correct per-model pricing if OpenAI changes rates (USD per 1M tokens).
# OPENAI_PRICE_OVERRIDES={"gpt-4o":{"input":2.5,"output":10}}

# ---- Live market pricing (grade reports; optional — AI fallback if unset) ----
# Cardmarket OAuth 1.0 (https://www.cardmarket.com/en/Pokemon/API) — raw EUR comps
# CARDMARKET_APP_TOKEN=
# CARDMARKET_APP_SECRET=
# CARDMARKET_ACCESS_TOKEN=
# CARDMARKET_ACCESS_TOKEN_SECRET=
# PriceCharting API token (https://www.pricecharting.com/api-documentation) — graded rows
# PRICECHARTING_API_TOKEN=
# EUR_TO_GBP=0.85
# USD_TO_GBP=0.79
# MARKET_PRICE_CACHE_HOURS=48
