  "mailer_templates_recovery_content": "<!DOCTYPE html><html lang=\"en-GB\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><meta name=\"color-scheme\" content=\"light\"><meta name=\"supported-color-schemes\" content=\"light\"><title>GemCheck</title></head><body style=\"margin:0;padding:0;background-color:#f4f5f8;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;-webkit-font-smoothing:antialiased;\"><div style=\"display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#f4f5f8;opacity:0;\">Reset your GemCheck password using the link inside.&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;</div><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#f4f5f8;\"><tr><td align=\"center\" style=\"padding:32px 16px;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:560px;background-color:#ffffff;border-radius:16px;border:1px solid #e8eaf0;\"><tr><td style=\"padding:28px 32px 8px;text-align:center;\"><a href=\"https://gemcheck.co.uk\" style=\"text-decoration:none;\"><img src=\"https://gemcheck.co.uk/gemcheck-logo-dark.png\" alt=\"GemCheck — by Looky\" width=\"200\" height=\"62\" style=\"display:block;margin:0 auto;height:62px;width:auto;max-width:200px;border:0;outline:none;text-decoration:none;background:transparent;\"></a><p style=\"margin:12px 0 0;font-size:12px;color:#5e6379;letter-spacing:0.02em;\">Know the grade before you submit</p></td></tr><tr><td style=\"padding:8px 32px 28px;color:#13151e;font-size:15px;line-height:1.65;\"><h1 style=\"margin:0 0 12px;font-size:22px;font-weight:700;line-height:1.3;color:#13151e;\">Reset your password</h1><p style=\"margin:0 0 16px;color:#5e6379;\">We received a request to reset the password for your GemCheck account. Choose a new password using the button below.</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:24px 0;\"><tr><td align=\"center\" style=\"border-radius:10px;background-color:#7c6cf6;\"><a href=\"{{ .ConfirmationURL }}\" target=\"_blank\" style=\"display:inline-block;padding:14px 28px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:10px;background-color:#7c6cf6;\">Reset password</a></td></tr></table><p style=\"margin:0 0 8px;font-size:13px;color:#5e6379;\">This link expires shortly and can only be used once.</p><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:20px 0 0;background-color:#f4f5f8;border-radius:10px;border:1px solid #e8eaf0;\"><tr><td style=\"padding:16px 20px;text-align:center;\"><p style=\"margin:0 0 8px;font-size:12px;color:#5e6379;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;\">Or use this code</p><p style=\"margin:0;font-size:28px;font-weight:700;letter-spacing:0.2em;color:#13151e;font-family:ui-monospace,'SF Mono',Monaco,Consolas,monospace;\">{{ .Token }}</p></td></tr></table><p style=\"margin:16px 0 0;font-size:13px;color:#5e6379;\">If you didn't request a password reset, you can safely ignore this email. Your password will not change.</p></td></tr><tr><td style=\"padding:20px 32px 28px;border-top:1px solid #e8eaf0;text-align:center;\"><p style=\"margin:0 0 8px;font-size:12px;color:#5e6379;line-height:1.5;\">GemCheck by Looky Collectibles · Lake District, UK</p><p style=\"margin:0;font-size:12px;line-height:1.5;\"><a href=\"https://gemcheck.co.uk\" style=\"color:#7c6cf6;text-decoration:none;font-weight:500;\">gemcheck.co.uk</a><span style=\"color:#c5c9d4;\"> · </span><a href=\"https://getlooky.uk\" style=\"color:#7c6cf6;text-decoration:none;font-weight:500;\">getlooky.uk</a></p></td></tr></table></td></tr></table></body></html>",
